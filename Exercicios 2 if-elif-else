n1 = float (input ("digite a primeira nota: "))
n2 = float (input ("digite a segunda nota: "))
n3 = float (input ("digite a terceira nota: "))
media = (n1 + n2 + n3) / 3
nota_recuperacao= 5.0
nota_minima = 7


print('A Nota Minima é:', nota_minima)

print (f"a média do aluno é: {media:.2f}")

if media >= nota_minima:
#tudo que tem esse "espaço" antes pertence ao IF
    print (f'O Aluno tirou {media:.2f}, então ele foi aprovado!')

elif media >= nota_recuperacao:
    print (f'O aluno tirou {media:.2f}, então ele está de recuperação ')

else:
    print (f'O Aluno tirou {media:.2f} Então ele foi reprovado')
